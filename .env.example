# OpenClaw runtime image settings
OPENCLAW_VERSION=2026.4.5
OPENCLAW_SOURCE_TAG=v2026.4.5
OPENCLAW_BASE_IMAGE=ghcr.io/openclaw/openclaw:2026.4.5
OPENCLAW_IMAGE=openclaw-local:2026.4.5-sandbox

# Host data root. All runtime config, workspace, cache, and logs will be stored here.
# You MUST replace this with your own absolute path before first run.
#
# Examples:
# - macOS:   /Users/yourname/openclaw_data
# - Linux:   /home/yourname/openclaw_data
# - Windows: C:/Users/yourname/openclaw_data
#
# For Windows, prefer forward slashes in `.env`.
OPENCLAW_HOST_DATA_ROOT=CHANGE_ME_ABSOLUTE_HOST_DATA_ROOT
OPENCLAW_TZ=Asia/Shanghai

# Gateway network settings
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# REQUIRED: replace with your own long random token.
# Example: openssl rand -hex 24
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_LONG_RANDOM_TOKEN

# REQUIRED: OpenAI-compatible endpoint and API key.
# Replace the host below with your own gateway / proxy / provider URL.
# Example only - do NOT use real production secrets in this file.
OPENAI_COMPATIBLE_BASE_URL=http://your-openai-compatible-host:3000/v1
OPENAI_COMPATIBLE_API_KEY=YOUR_OPENAI_COMPATIBLE_API_KEY

# Optional providers. Leave placeholder values if unused.
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Optional Feishu integration. Leave placeholder values if unused.
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=YOUR_FEISHU_APP_SECRET

DOCKER_SOCKET_PATH=/var/run/docker.sock

# Optional: let the gateway container and sandbox containers reach host-side
# services such as Clash / Surge / v2rayN running on the host.
#
# Recommended when your host can "科学上网" but Docker containers cannot.
#
# Usage:
# 1. Set OPENCLAW_SANDBOX_NETWORK=bridge
# 2. Point HTTP(S)_PROXY / ALL_PROXY to host.docker.internal
# 3. Leave OPENCLAW_PROXY_MODE=auto for automatic fallback to direct mode when proxy is unreachable
# 4. Re-run ./scripts/init-data-dir.sh and restart the gateway container
#
# Examples:
# HTTP_PROXY=http://host.docker.internal:7890
# HTTPS_PROXY=http://host.docker.internal:7890
# ALL_PROXY=socks5://host.docker.internal:7890
OPENCLAW_SANDBOX_NETWORK=none
OPENCLAW_SANDBOX_EXTRA_HOST=host.docker.internal:host-gateway
OPENCLAW_PROXY_MODE=auto
OPENCLAW_PROXY_PROBE_TIMEOUT_MS=1500
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1,host.docker.internal

# Optional: Control UI locale + bilingual terminology overlay. These settings are baked into the image at build time.
# `OPENCLAW_CONTROL_UI_TEXT_MODE_DEFAULT` supports: zh-only / zh-en / en-only
# After changing them, run: docker compose build && docker compose up -d --force-recreate openclaw-gateway
OPENCLAW_CONTROL_UI_DEFAULT_LOCALE=zh-CN
OPENCLAW_CONTROL_UI_FORCE_LOCALE=
OPENCLAW_CONTROL_UI_ENABLED_LOCALES=auto,zh-CN,zh-TW,en
OPENCLAW_CONTROL_UI_SHOW_LOCALE_SWITCHER=true
OPENCLAW_CONTROL_UI_TEXT_MODE_DEFAULT=zh-en
OPENCLAW_CONTROL_UI_ENABLED_TEXT_MODES=zh-only,zh-en,en-only

# Optional sandbox build tuning.
SANDBOX_APT_RETRIES=10
SANDBOX_APT_INSTALL_ATTEMPTS=6
SANDBOX_APT_RETRY_SLEEP=15
# SANDBOX_DEBIAN_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/debian
# SANDBOX_DEBIAN_SECURITY_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/debian-security

# Runtime user mapping.
#
# Recommended values:
# - macOS:   run `id -u` and `id -g`, often `501:20`
# - Linux:   run `id -u` and `id -g`, often `1000:1000`
# - Windows: first try `1000:1000`; only change it if you hit Docker socket or file permission issues
OPENCLAW_RUN_USER=1000:1000

# Admin UI runtime settings. These are runtime-only; after changing them, run: docker compose up -d --force-recreate openclaw-admin-ui
OPENCLAW_ADMIN_UI_PORT=18889
OPENCLAW_ADMIN_UI_TOKEN=CHANGE_ME_ADMIN_TOKEN


# Platform control-plane database (MySQL).
# The platform layer uses MySQL to store user accounts, sessions, private providers, and lobster metadata.
OPENCLAW_PLATFORM_MYSQL_DATABASE=openclaw_platform
OPENCLAW_PLATFORM_MYSQL_USER=openclaw
OPENCLAW_PLATFORM_MYSQL_PASSWORD=CHANGE_ME_PLATFORM_MYSQL_PASSWORD
OPENCLAW_PLATFORM_MYSQL_ROOT_PASSWORD=CHANGE_ME_PLATFORM_MYSQL_ROOT_PASSWORD
OPENCLAW_PLATFORM_MYSQL_PORT_EXPOSE=23306
OPENCLAW_PLATFORM_CRYPTO_SECRET=CHANGE_ME_PLATFORM_CRYPTO_SECRET_AT_LEAST_16_CHARS
OPENCLAW_PLATFORM_SESSION_TTL_DAYS=14
OPENCLAW_PLATFORM_DEFAULT_MODEL=default/gpt-5.4
OPENCLAW_PLATFORM_BOOTSTRAP_ADMIN_EMAIL=admin@openclaw.local
OPENCLAW_PLATFORM_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_PLATFORM_ADMIN_PASSWORD
OPENCLAW_PLATFORM_NAME=OpenClaw 平台
OPENCLAW_CLAWSWARM_ENABLED=true
OPENCLAW_CLAWSWARM_PORT=18080
OPENCLAW_CLAWSWARM_INTERNAL_URL=http://openclaw-clawswarm:18080
OPENCLAW_CLAWSWARM_PUBLIC_URL=http://localhost:18080
OPENCLAW_CLAWSWARM_USERNAME=admin
OPENCLAW_CLAWSWARM_PASSWORD=admin123456
OPENCLAW_CLAWSWARM_SOURCE_REF=main
OPENCLAW_CLAWSWARM_BASE_IMAGE=openclaw-clawswarm-base-local:main
OPENCLAW_CLAWSWARM_IMAGE=openclaw-clawswarm-local:main

